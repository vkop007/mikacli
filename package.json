{
  "name": "autocli",
  "version": "0.1.0",
  "description": "Bun-first CLI for browserless social media automation using imported web sessions.",
  "type": "module",
  "license": "MIT",
  "packageManager": "bun@1.3.6",
  "keywords": [
    "bun",
    "cli",
    "automation",
    "instagram",
    "twitter",
    "x"
  ],
  "bin": {
    "autocli": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "dev:watch": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "prepare": "bun run build",
    "link:global": "bun run scripts/link-global.ts",
    "typecheck": "tsc --noEmit",
    "build": "bun build --target=node --format=esm --outdir dist ./src/index.ts",
    "build:bin": "bun build --compile --target=bun --outfile bin/autocli ./src/index.ts",
    "test": "bun test"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "fetch-cookie": "^3.2.0",
    "ora": "^9.3.0",
    "picocolors": "^1.1.1",
    "tough-cookie": "^6.0.1",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/ws": "^8.18.1",
    "bun-types": "^1.3.11",
    "typescript": "^5.9.3"
  }
}
